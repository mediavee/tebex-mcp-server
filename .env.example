# Tebex Plugin API secret key (Creator Panel > Game Servers > Secret Key)
TEBEX_SECRET=

# Bearer token required by Claude clients to talk to this MCP server.
# Generate one with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# HTTP bind address and port
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
