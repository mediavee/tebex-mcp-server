# Bearer token required by Claude clients to talk to this MCP server.
# Generate one with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# HTTP bind address and port
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# NOTE: the Tebex Plugin API secret is NOT configured here. It is provided
# per-request by the MCP client through the X-Tebex-Secret HTTP header so a
# single instance can serve any number of stores. Configure your secret(s)
# on the client side (see README — Multi-store usage).
